# --- GreenNode AI Platform LLM (OpenAI-compatible) ---
LLM_API_KEY=
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_MODEL=qwen/qwen3-5-27b

# --- Zalo Bot ---
# Token dạng "<id>:<random>" lấy từ OA "Zalo Bot Manager"
ZALO_BOT_TOKEN=
# (tùy chọn) đổi base URL Zalo Bot API nếu cần
# ZALO_API_BASE=https://bot-api.zaloplatforms.com

# Lưu ý: GREENNODE_CLIENT_ID / GREENNODE_CLIENT_SECRET / GREENNODE_AGENT_IDENTITY /
# GREENNODE_ENDPOINT_URL được AgentBase Runtime tự inject — KHÔNG đặt thủ công.
